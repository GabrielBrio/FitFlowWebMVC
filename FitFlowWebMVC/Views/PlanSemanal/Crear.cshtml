@model FitFlowWebMVC.Models.PlanSemanal

@{
    ViewData["Title"] = "Crear Plan Semanal";
}

<div class="container">

    <h1>Plan de Entrenamiento</h1>

    <p>
        Registra tu rutina para comenzar la automatización de FitFlow.
    </p>

    <form asp-action="Crear" method="post">

        <div class="form-group">
            <label>Día</label>
            <select asp-for="Dia" class="form-control">
                <option value="">Seleccione un día</option>
                <option>Lunes</option>
                <option>Martes</option>
                <option>Miércoles</option>
                <option>Jueves</option>
                <option>Viernes</option>
                <option>Sábado</option>
                <option>Domingo</option>
            </select>
        </div>

        <div class="form-group">
            <label>Grupo Muscular</label>
            <input asp-for="GrupoMuscular"
                   class="form-control"
                   placeholder="Ej: Pecho" />
        </div>

        <div class="form-group">
            <label>Ejercicio</label>
            <input asp-for="Ejercicio"
                   class="form-control"
                   placeholder="Ej: Press Banca" />
        </div>

        <div class="form-group">
            <label>Series</label>
            <input asp-for="Series"
                   type="number"
                   class="form-control" />
        </div>

        <div class="form-group">
            <label>Repeticiones</label>
            <input asp-for="Repeticiones"
                   type="number"
                   class="form-control" />
        </div>

        <div class="form-group">
            <label>Peso (kg)</label>
            <input asp-for="Peso"
                   type="number"
                   step="0.5"
                   class="form-control" />
        </div>

        <br />

        <button type="submit" class="btn btn-primary">
            Guardar Plan
        </button>

    </form>

</div>